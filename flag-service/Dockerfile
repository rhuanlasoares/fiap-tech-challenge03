FROM python:3.13.13-slim-bookworm AS builder
# FROM python:3.13.13-alpine AS builder

WORKDIR /app

# RUN apt-get update && apt-get upgrade -y && \
#     apt-get install -y --no-install-recommends && \
#     rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

FROM python:3.13.13-slim-bookworm AS production
# FROM python:3.13.13-alpine AS production

RUN adduser -D -s /bin/sh appuser

# RUN useradd --create-home --shell /bin/bash appuser

RUN apk update && apk upgrade && \
    apk add --no-cache postgresql-client

# RUN apt-get update && apt-get upgrade -y && \
#     apt-get install -y --no-install-recommends postgresql-client && \
#     rm -rf /var/lib/apt/lists/*
    
WORKDIR /app

COPY --from=builder /root/.local /home/appuser/.local
COPY --chown=appuser:appuser app.py app.py

ENV PATH=/home/appuser/.local/bin:$PATH \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

USER appuser

EXPOSE 8002

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/health')" || exit 1

CMD ["gunicorn", "--bind", "0.0.0.0:8002", "app:app"]
