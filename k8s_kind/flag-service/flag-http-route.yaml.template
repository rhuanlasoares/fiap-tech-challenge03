---
kind: HTTPRoute
apiVersion: gateway.networking.k8s.io/v1
metadata:
  name: flag-service-route
  namespace: flag-ns
spec:
  parentRefs:
  - name: gateway-applications
    namespace: gateway-api-ns
  hostnames:
  - "rhuan-fiap.${GATEWAY_IP}.nip.io"
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /flag-service
    backendRefs:
    - name: flag-service
      port: 80
