---
kind: HTTPRoute
apiVersion: gateway.networking.k8s.io/v1
metadata:
  name: argocd-service-route
  namespace: argocd
spec:
  parentRefs:
  - name: gateway-applications
    namespace: gateway-api-ns
  hostnames:
  - "argocd.${GATEWAY_IP}.nip.io"
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /
    backendRefs:
    - name: argocd-server
      port: 80
